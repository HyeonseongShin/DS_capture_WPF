<Window x:Class="DSCapture.Views.DragCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowState="Maximized" ShowInTaskbar="False">
    <Canvas x:Name="MainCanvas" Background="Transparent"
            MouseMove="OnMouseMove"
            MouseLeftButtonDown="OnMouseDown"
            MouseLeftButtonUp="OnMouseUp">

        <!-- 어두운 스크린샷 배경 -->
        <Image x:Name="DarkBackground" Canvas.Left="0" Canvas.Top="0" Stretch="None"/>

        <!-- 선택 영역 원본 미리보기 -->
        <Image x:Name="PreviewImage" Canvas.Left="0" Canvas.Top="0" Stretch="None"/>

        <!-- 십자선 -->
        <Line x:Name="VLine" Stroke="Red" StrokeThickness="1.5" Opacity="0.8"/>
        <Line x:Name="HLine" Stroke="Red" StrokeThickness="1.5" Opacity="0.8"/>

        <!-- 선택 박스 -->
        <Rectangle x:Name="SelectBox" Stroke="Red" StrokeThickness="2.5"
                   Fill="Transparent" Visibility="Collapsed"/>

        <!-- 크기 레이블 배경 -->
        <Border x:Name="SizeBg" Background="Black" Padding="4,2" Visibility="Collapsed">
            <TextBlock x:Name="SizeLabel" Foreground="White"
                       FontFamily="Malgun Gothic" FontSize="12" FontWeight="Bold"/>
        </Border>

        <!-- 상단 안내 텍스트 -->
        <Border x:Name="HintBorder" Background="#CC1e1e1e" Padding="12,6">
            <TextBlock Foreground="#f1c40f" FontFamily="Malgun Gothic" FontSize="11" FontWeight="Bold"
                       Text="[Shift] 비율 고정    [Ctrl] 중앙 기준 드래그    [Ctrl+Shift] 중앙+비율 고정    [ESC] 취소"/>
        </Border>
    </Canvas>
</Window>
