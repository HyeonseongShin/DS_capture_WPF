<Window x:Class="DSCapture.Views.LicenseErrorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="라이센스 인증 필요" Width="450" Height="270"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Topmost="True" Background="#1e272e">
    <StackPanel Margin="30,20">
        <TextBlock Text="라이센스 인증이 필요합니다."
                   Foreground="#ff4757" FontSize="14" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <TextBlock x:Name="MessageText" Foreground="White" FontSize="11"
                   TextWrapping="Wrap" HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <TextBlock Text="기기 고유 ID" Foreground="#a4b0be" FontSize="10"
                   HorizontalAlignment="Center"/>
        <TextBlock x:Name="HwidText" Foreground="#00d2d3"
                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,4,0,16"/>

        <Button Content="기기 ID 복사하기" Click="OnCopyClick"
                Background="#4b6584" Foreground="White" FontWeight="Bold"
                BorderThickness="0" Padding="20,7" Cursor="Hand"
                HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <TextBlock Text="관리자에게 문의하세요." Foreground="#a4b0be" FontSize="10"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
