<Window x:Class="DSCapture.Views.FixedBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize"
        Left="200" Top="200">
    <Grid x:Name="RootGrid">
        <!-- 히트 테스트용 거의 투명한 전체 배경 (리사이즈 핸들 영역 캡처) -->
        <Rectangle x:Name="HitArea" Fill="#01000000"/>

        <!-- 캡처 영역 빨간 테두리 -->
        <Border x:Name="CaptureBorder" BorderBrush="#ff4757" BorderThickness="4"
                Background="Transparent"/>

        <!-- 컨트롤 바 (상단) -->
        <Border x:Name="TopBar" Height="40" Background="#1e1e1e"
                VerticalAlignment="Top">
            <DockPanel Margin="8,0">
                <Button x:Name="CloseBtn" Content=" ✕ " DockPanel.Dock="Right"
                        Background="#1e1e1e" Foreground="#f1c40f"
                        FontSize="14" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="OnClose"/>
                <Button x:Name="CaptureBtn" Content=" CAPTURE (Enter) "
                        DockPanel.Dock="Right" Background="#00ff7f" Foreground="#000000"
                        FontFamily="Malgun Gothic" FontSize="9" FontWeight="Bold"
                        BorderThickness="0" Margin="0,5,8,5" Padding="10,3"
                        Cursor="Hand" Click="OnCapture"/>
                <TextBlock x:Name="SizeLabel" Foreground="#f1c40f"
                           FontFamily="Malgun Gothic" FontSize="13" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
