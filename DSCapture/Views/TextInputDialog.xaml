<Window x:Class="DSCapture.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="텍스트 입력" Width="320" Height="130"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="입력할 텍스트:" Margin="0,0,0,6" FontFamily="Malgun Gothic"/>
        <TextBox x:Name="InputBox" Margin="0,0,0,10" FontSize="12" Padding="4"
                 KeyDown="OnKeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인" Width="70" Padding="0,5" Margin="0,0,8,0"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="취소" Width="70" Padding="0,5"
                    IsCancel="True" Click="OnCancel"/>
        </StackPanel>
    </StackPanel>
</Window>
