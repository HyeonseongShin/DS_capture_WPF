<Window x:Class="DSCapture.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경설정 (Settings)" Width="400" Height="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1e272e">
    <Window.Resources>
        <Style x:Key="SettingBtn" TargetType="Button">
            <Setter Property="Background" Value="#4b6584"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Malgun Gothic"/>
        </Style>
        <Style x:Key="ToggleOn" TargetType="Button" BasedOn="{StaticResource SettingBtn}">
            <Setter Property="Background" Value="#00d2d3"/>
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#a4b0be"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,20">
            <Button Content="단축키 지정" Style="{StaticResource SettingBtn}"
                    Click="OnShortcutClick" Margin="0,0,0,4"/>
            <Button Content="저장 위치 지정" Style="{StaticResource SettingBtn}"
                    Click="OnSaveDirClick" Margin="0,0,0,4"/>
            <TextBlock x:Name="CurrentSaveDirLabel" Foreground="#00d2d3" FontSize="10" 
                       Margin="4,0,0,10" TextWrapping="Wrap"/>
            <Button Content="저장 폴더 열기" Style="{StaticResource SettingBtn}"
                    Click="OnOpenFolderClick"/>

            <TextBlock Text="저장 파일 형식" Style="{StaticResource SectionLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnPng" Content="PNG" Grid.Column="0"
                        Style="{StaticResource SettingBtn}" Click="OnPngClick"
                        Margin="0,0,2,0"/>
                <Button x:Name="BtnJpg" Content="JPG" Grid.Column="1"
                        Style="{StaticResource SettingBtn}" Click="OnJpgClick"
                        Margin="2,0,0,0"/>
            </Grid>

            <TextBlock Text="닫기 버튼 동작" Style="{StaticResource SectionLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnTray" Content="트레이로" Grid.Column="0"
                        Style="{StaticResource SettingBtn}" Click="OnTrayClick"
                        Margin="0,0,2,0"/>
                <Button x:Name="BtnExit" Content="완전 종료" Grid.Column="1"
                        Style="{StaticResource SettingBtn}" Click="OnExitClick"
                        Margin="2,0,0,0"/>
            </Grid>

            <TextBlock Text="윈도우 시작 시 자동실행" Style="{StaticResource SectionLabel}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnStartupOn" Content="자동실행 켬" Grid.Column="0"
                        Style="{StaticResource SettingBtn}" Click="OnStartupOnClick"
                        Margin="0,0,2,0"/>
                <Button x:Name="BtnStartupOff" Content="자동실행 끔" Grid.Column="1"
                        Style="{StaticResource SettingBtn}" Click="OnStartupOffClick"
                        Margin="2,0,0,0"/>
            </Grid>

            <Separator Background="#3d3d3d" Margin="0,20,0,10"/>
            <Grid>
                <TextBlock x:Name="VersionLabel" Foreground="#a4b0be" FontSize="10"
                           HorizontalAlignment="Left"/>
                <TextBlock x:Name="BuildLabel" Foreground="#a4b0be" FontSize="10"
                           HorizontalAlignment="Right"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
